// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String?
  action      String
  resource    String
  resourceId  String?
  details     String?
  ipAddress   String?
  userAgent   String?
  status      String   @default("success")
  createdAt   DateTime @default(now())

  user        User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([resource])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@map("audit_logs")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("USER")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions         Session[]
  auditLogs        AuditLog[]
  createdTasks     Task[] @relation("CreatedBy")
  updatedTasks     Task[] @relation("UpdatedBy")
  assignedTasks    Task[] @relation("AssignedTo")
  completedTasks   Task[] @relation("CompletedBy")

  @@index([role])
  @@index([isActive])
  @@index([createdAt])
  @@map("users")
}

model Task {
  id          String   @id @default(uuid())
  title       String
  description String?
  status      String   @default("PENDING")
  priority    String   @default("MEDIUM")
  dueDate     DateTime?
  completedAt DateTime?
  tags        String
  order       Int      @default(0) // 用于拖拽排序
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdById  String?
  createdBy    User?  @relation("CreatedBy", fields: [createdById], references: [id])
  updatedById  String?
  updatedBy    User?  @relation("UpdatedBy", fields: [updatedById], references: [id])
  assignedToId String?
  assignedTo   User?  @relation("AssignedTo", fields: [assignedToId], references: [id])
  completedById String?
  completedBy  User?  @relation("CompletedBy", fields: [completedById], references: [id])

  // 任务依赖关系
  dependencies TaskDependency[] @relation("TaskDependencies")
  dependents   TaskDependency[] @relation("TaskDependents")

  @@index([createdById])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
  @@index([status, createdAt])
  @@index([createdById, status])
  @@index([order])
  @@map("tasks")
}

// 任务依赖关系表
model TaskDependency {
  id          String   @id @default(uuid())
  taskId      String   // 当前任务
  dependsOnId String   // 依赖的任务
  type        String   @default("BLOCKS") // BLOCKS, RELATES_TO, DUPLICATES
  createdAt   DateTime @default(now())

  task        Task     @relation("TaskDependencies", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOn   Task     @relation("TaskDependents", fields: [dependsOnId], references: [id], onDelete: Cascade)

  @@unique([taskId, dependsOnId])
  @@index([taskId])
  @@index([dependsOnId])
  @@map("task_dependencies")
}

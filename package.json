{
  "name": "taskmanager",
  "version": "2.0.0",
  "description": "TaskManager - 企业级任务管理系统",
  "private": true,
  "scripts": {
    "install:all": "npm install && cd src/backend && npm install && cd ../frontend && npm install",
    "start": "npm-run-all --parallel start:*",
    "start:backend": "cd src/backend && npm start",
    "start:frontend": "cd src/frontend && npm start",
    "test": "npm-run-all test:*",
    "test:backend": "cd src/backend && npm test",
    "test:frontend": "cd src/frontend && npm test",
    "lint": "npm-run-all lint:*",
    "lint:backend": "cd src/backend && npm run lint",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
